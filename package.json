{
  "name": "crossfriends",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:sandbox": "wrangler pages dev dist --d1=crossfriends-production --local --ip 0.0.0.0 --port 3000",
    "build": "vite build",
    "preview": "wrangler pages dev dist",
    "deploy": "npm run build && wrangler pages deploy dist --commit-dirty=true --commit-message=deploy",
    "deploy:prod": "npm run build && wrangler pages deploy dist --project-name crossfriends --commit-dirty=true --commit-message=deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "clean-port": "fuser -k 3000/tcp 2>/dev/null || true",
    "test": "curl http://localhost:3000",
    "db:migrate:local": "wrangler d1 migrations apply crossfriends-production --local",
    "db:migrate:prod": "wrangler d1 migrations apply crossfriends-production",
    "db:seed": "wrangler d1 execute crossfriends-production --local --file=./seed.sql",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:local && npm run db:seed",
    "db:console:local": "wrangler d1 execute crossfriends-production --local",
    "db:console:prod": "wrangler d1 execute crossfriends-production",
    "hash-password": "node scripts/hash-password.mjs"
  },
  "dependencies": {
    "hono": "^4.11.4"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "autoprefixer": "^10.4.24",
    "playwright": "^1.59.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.0",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
