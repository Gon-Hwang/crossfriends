{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "crossfriends",
  "compatibility_date": "2026-01-19",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "crossfriends-production",
      "database_id": "b1bd107b-7731-4abc-8f09-10ce94bcec7a"
    }
  ],
  "r2_buckets": [
    {
      "binding": "R2",
      "bucket_name": "crossfriends-avatars"
    }
  ]
}